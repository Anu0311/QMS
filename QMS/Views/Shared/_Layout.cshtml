<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - YourApp</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    <div class="page-content">
        <!-- Main sidebar -->
        <div class="card card-sidebar-mobile">
            <ul class="nav nav-sidebar" data-nav-type="accordion">
                <!-- Dashboard -->
                <li class="nav-item">
                    <a asp-controller="Dashboard" asp-action="Index" class="nav-link" title="Dashboard">
                        <i class="fa-solid fa-house"></i>
                        <span>Dashboard</span>
                    </a>
                </li>

                <!-- Vendor -->
                <li class="nav-item nav-item-submenu">
                    <a href="#" class="nav-link"><i class="fa-solid fa-industry"></i> <span>Vendor</span></a>
                    <ul class="nav nav-group-sub" data-submenu-title="Vendor">
                        <li class="nav-item">
                            <a asp-controller="VendorCertifications" asp-action="Index" class="nav-link">Vendor Certifications</a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="ValidationReports" asp-action="Index" class="nav-link">Validation Reports</a>
                        </li>
                    </ul>
                </li>

                <!-- Validation Details -->
                <li class="nav-item nav-item-submenu">
                    <a href="#" class="nav-link"><i class="fa-solid fa-check-double"></i> <span>Vendor Validation Details</span></a>
                    <ul class="nav nav-group-sub" data-submenu-title="Vendor Validation">
                        <li class="nav-item">
                            <a asp-controller="CustomerComplaints" asp-action="Index" class="nav-link">Internal Customer Complaints</a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="SupplierPerformance" asp-action="Index" class="nav-link">SPM Summary</a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="ThirdPartyTesting" asp-action="Index" class="nav-link">Third Party Testing</a>
                        </li>
                    </ul>
                </li>

                <!-- BIS -->
                <li class="nav-item nav-item-submenu">
                    <a href="#" class="nav-link"><i class="fa-solid fa-certificate"></i> <span>BIS</span></a>
                    <ul class="nav nav-group-sub" data-submenu-title="BIS">
                        <li class="nav-item">
                            <a asp-controller="BISGrant" asp-action="Index" class="nav-link">New BIS Grant</a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="CCL" asp-action="Index" class="nav-link">CCL Updation</a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="SeriesAddition" asp-action="Index" class="nav-link">Series Addition</a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="RandomTesting" asp-action="Index" class="nav-link">Random Performance Testing</a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="ESGData" asp-action="Index" class="nav-link">ESG Monthly Data</a>
                        </li>
                    </ul>
                </li>

                <!-- Service -->
                <li class="nav-item nav-item-submenu">
                    <a href="#" class="nav-link"><i class="fa-solid fa-tools"></i> <span>Service</span></a>
                    <ul class="nav nav-group-sub" data-submenu-title="Service">
                        <li class="nav-item">
                            <a asp-controller="RLTCalculation" asp-action="Index" class="nav-link">RLT Calculation</a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="COPQ" asp-action="Index" class="nav-link">COPQ</a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="CustomerComplaint" asp-action="Index" class="nav-link">Customer Complaint</a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="ComplaintClosure" asp-action="Index" class="nav-link">On Time Complaint Closure</a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="QualityAudit" asp-action="Index" class="nav-link">Installed Quality Audit</a>
                        </li>
                    </ul>
                </li>
            </ul>
        </div>
        <!-- /main sidebar -->
        <!-- Main content -->
        <div class="content-wrapper">
            @RenderBody()
        </div>
        <!-- /main content -->
    </div>

    @RenderSection("Scripts", required: false)

</body>
</html>
